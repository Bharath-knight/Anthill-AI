# Supabase — get both from: Supabase dashboard > Settings > Database > Connection string
# Use "Transaction" mode URL for DATABASE_URL (port 6543)
# Use "Session" mode URL for DIRECT_URL (port 5432)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long

NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# MVP dev only — set to a real user ID from your DB (skip auth for now)
DEV_USER_ID=

# Google Calendar two-way sync (optional — the calendar works locally without it).
# Create at console.cloud.google.com: enable "Google Calendar API", configure the
# OAuth consent screen (External; add yourself as a Test user), then create an
# OAuth client ID (Web application) with these Authorized redirect URIs:
#   http://localhost:3000/api/google/callback
#   https://anthill-ai.vercel.app/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override the redirect URI (defaults to <request-origin>/api/google/callback)
GOOGLE_REDIRECT_URI=
