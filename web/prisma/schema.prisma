generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?  // null for accounts created via Google Sign-In
  googleId  String?  @unique // Google account id (sub); set when linked to Google
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs           Job[]
  research       ResearchItem[]
  tasks          Task[]
  calendarEvents CalendarEvent[]
  googleAccount  GoogleAccount?
  passwordResets PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Job {
  id        String    @id @default(cuid())
  userId    String
  company   String
  role      String
  location  String?
  deadline  String    @default("Deadline not given")
  link      String
  rawText   String
  notes     String?
  status    JobStatus @default(SAVED)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks  Task[]
  events JobEvent[]

  @@unique([userId, link])
}

model JobEvent {
  id         String   @id @default(cuid())
  jobId      String
  type       String
  fromStatus String?
  toStatus   String?
  createdAt  DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

enum JobStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model ResearchItem {
  id        String   @id @default(cuid())
  userId    String
  content   String
  sourceUrl String?
  domain    String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches Match[]
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  deadline    DateTime?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  linkedJob   Job?    @relation(fields: [linkedJobId], references: [id])
  linkedJobId String?
  matches     Match[]
}

model Match {
  id              String      @id @default(cuid())
  researchItemId  String
  taskId          String
  matchScore      Float
  matchedKeywords String[]
  status          MatchStatus @default(PENDING)
  createdAt       DateTime    @default(now())

  researchItem ResearchItem @relation(fields: [researchItemId], references: [id], onDelete: Cascade)
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([researchItemId, taskId])
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model CalendarEvent {
  id        String    @id @default(cuid())
  userId    String
  title     String
  start     DateTime
  end       DateTime
  allDay    Boolean   @default(false)
  type      EventType @default(PERSONAL)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Google Calendar two-way sync. source marks where the event originated;
  // googleEventId links it to the corresponding Google event (null until synced);
  // googleUpdated is Google's last-modified stamp, used for last-write-wins.
  source        EventSource @default(ANTHILL)
  googleEventId String?
  googleUpdated DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, googleEventId])
  @@index([userId, start])
}

enum EventType {
  JOB
  RESEARCH
  PERSONAL
  FOCUS
}

enum EventSource {
  ANTHILL
  GOOGLE
}

// A user's connected Google Calendar. Tokens are stored encrypted (AES-GCM via
// lib/crypto.ts); never expose them to the client. One account per user (MVP:
// the primary calendar only).
model GoogleAccount {
  id           String   @id @default(cuid())
  userId       String   @unique
  googleEmail  String
  accessToken  String
  refreshToken String
  expiry       DateTime
  scope        String
  syncToken    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
