{
  "manifest_version": 3,
  "name": "Anthill",
  "version": "1.0.2",
  "description": "Capture jobs, research, and notes from your clipboard",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://anthill-ai.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Anthill — Job Capture"
  },
  "background": {
    "service_worker": "background.js"
  }
}
