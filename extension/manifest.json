{
  "manifest_version": 3,
  "name": "Anthill",
  "version": "1.1.0",
  "description": "Copy a link and Anthill offers to file it away — jobs, articles, and more — into your workspace.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://anthill-ai.vercel.app/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Anthill — Quick Capture"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
